# ═══════════════════════════════════════
# SENDFLOW — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════

# ── REQUIRED ────────────────────────────
TELEGRAM_BOT_TOKEN=              # Get from @BotFather
SOLANA_ESCROW_WALLET_PRIVATE_KEY=# Base58 private key of escrow wallet
SENDER_WALLET_PRIVATE_KEY=       # Base58 private key of sender wallet
WALLET_ENCRYPTION_KEY=           # 32+ char random string — NEVER share this

# ── SOLANA ──────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_RPC_URL=                  # Recommended: get free key at helius.dev
QUICKNODE_RPC_URL=               # Optional second RPC
# RPC_POOL=                      # Comma-separated pool (optional)
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ── LLM (NOSANA) ────────────────────────
NOSANA_LLM_ENDPOINT=             # Your Nosana deployment URL (origin used for /api/tags + /api/chat)
NOSANA_API_KEY=                  # Optional: bearer token
ELIZA_MODEL=qwen3.5:9b

# ── TELEGRAM ────────────────────────────
TELEGRAM_BOT_USERNAME=SendFlowSol_bot
ADMIN_TELEGRAM_ID=               # Your numeric Telegram user ID

# ── TRANSFER LIMITS ─────────────────────
MIN_TRANSFER_USDC=0.1
MAX_TRANSFER_USDC=100

# ── P2P MARKETPLACE ─────────────────────
P2P_MAX_TRADE_NEW_USER=10
P2P_MAX_DAY_NEW_USER=20
P2P_MAX_TRADE_REGULAR=100
P2P_MAX_DAY_REGULAR=500
P2P_MAX_TRADE_TRUSTED=500
P2P_MAX_DAY_TRUSTED=2000
P2P_MAX_TRADE_VERIFIED=2000
P2P_MAX_DAY_VERIFIED=10000
P2P_OFFER_EXPIRY_HOURS=24
P2P_TRADE_TIMEOUT_MINUTES=30
P2P_DISPUTE_ADMIN_ALERT=true
P2P_MIN_TRADE_USDC=1
# Legacy KYC link builders (optional; velocity tiers in offrampOracle)
MOONPAY_URL=
TRANSAK_API_KEY=

# ── SMS (OPTIONAL) ──────────────────────
TWILIO_ACCOUNT_SID=              # For phone number recipient invites
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── VOICE (OPTIONAL) ────────────────────
WHISPER_ENDPOINT=                # Nosana Whisper deployment URL

# ── PRICE FEEDS ─────────────────────────
JUPITER_API_URL=https://quote-api.jup.ag/v6
JUPITER_PRICE_API_URL=https://price.jup.ag/v6
PYTH_PRICE_SERVICE_URL=https://hermes.pyth.network

# ── COMPLIANCE (OPTIONAL) ───────────────
CHAINALYSIS_API_KEY=             # Required for production off-ramp screening
SCAN_WALLET_BLOCKLIST=           # Comma-separated blocked wallet addresses

# ── FEATURES ────────────────────────────
MINT_RECEIPTS=false
DAILY_DIGEST_ENABLED=true
WEEKLY_REPORT_ENABLED=true
WEEKLY_REPORT_UTC_HOUR=9

# ── INFRA ───────────────────────────────
PORT=3000
NODE_ENV=development
SENDFLOW_DATA_DIR=               # Default: ./data (contacts, tx history, invoices, SendFlow IDs, wallets)
WEBAPP_PUBLIC_URL=             # Your Nosana deployment public URL (Telegram WebApp menu)
SENDFLOW_BASE_URL=https://sendflow.app

# ── E2E Testing ─────────────────────────
TEST_DEVNET_WALLET_PRIVATE_KEY=
SENDFLOW_E2E=false
E2E_PORT=3001

# ── DEMO ────────────────────────────────
DEMO_ESCROW_WALLET_PRIVATE_KEY=  # Funded wallet for /admin demo
DEMO_RECIPIENT_WALLET=           # Recipient for demo transfer
STRESS_USE_LLM=false

# ── GITHUB / LANDING PAGE ───────────────
GITHUB_URL=https://github.com/YOUR_USERNAME/sendflow
HACKATHON_NAME=Nosana Builders Challenge
ESCROW_WALLET_PUBLIC_KEY=        # For Solscan link on landing page

# ── SAVINGS ENGINE ──────────────────────
SOL_PRICE_USD=150
SENDFLOW_WU_RATE=0.05
SENDFLOW_MG_RATE=0.06

# ── OPTIONAL INTEGRATIONS ───────────────
SQUADS_PROGRAM_ID=SQDS4ep65T869zMMBKyuUq6aD6EgTu8psMjkvj52pCf
SPONSOR_WALLET_PRIVATE_KEY=
REFERRAL_REWARD_USDC=0.1
BIRDEYE_API_KEY=
DEFI_LLAMA_URL=https://yields.llama.fi/pools
LOAN_MAX_AMOUNT=100
LOAN_INTEREST_RATE=0.02
STREAM_SETTLEMENT_INTERVAL_MS=300000
POS_INVOICE_EXPIRY_MS=600000
OFFRAMP_TIER0_LIMIT=100
OFFRAMP_TIER1_LIMIT=500
OFFRAMP_TIER2_LIMIT=2000
VIRTUAL_CARD_PROVIDER=stub
SENDFLOW_SENDER_DISPLAY_NAME=
